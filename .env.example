# ── Oura ──────────────────────────────────────────────────────────────────
# Generate at: https://cloud.ouraring.com/personal-access-tokens
OURA_PAT=replace_me

# ── TimescaleDB ───────────────────────────────────────────────────────────
POSTGRES_DB=oura
POSTGRES_USER=oura
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_PORT=5432

# ── Grafana ──────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me
GF_SERVER_ROOT_URL=http://localhost:3000
GRAFANA_PORT=3000

# ── Sync (Oura → DB) ──────────────────────────────────────────────────────
SYNC_SCHEDULE=0 */3 * * *      # every 3 hours
BACKFILL_DAYS=730              # initial 2-year backfill

# ── App: passcode auth ───────────────────────────────────────────────────
# Single-user app; this passcode is what you type to log in.
APP_PASSCODE=change-me-to-something-long
JWT_SECRET=change-me-to-32+-random-bytes
JWT_TTL_DAYS=30

# ── App: Anthropic ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-opus-4-6

# ── App: CORS ────────────────────────────────────────────────────────────
# In dev, leave as "*". On Railway, set to your app's public URL once known.
CORS_ORIGIN=*

# ── App: digest email (optional, only used by the digest cron) ───────────
RESEND_API_KEY=
DIGEST_EMAIL_FROM=digest@your-domain.com
DIGEST_EMAIL_TO=atharvaamritkar0@gmail.com

# ── App: profile (used in LLM prompts) ───────────────────────────────────
USER_NAME=Atharva
USER_AGE=0
USER_TIMEZONE=Asia/Kolkata

# ── App: ports & wiring (compose only — Railway uses service refs) ───────
API_PORT=8000
APP_PORT=3001
API_BASE_URL=http://api:8000
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3000
