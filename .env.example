# Oura Ring Personal Access Token
# Generate at: https://cloud.ouraring.com/personal-access-tokens
OURA_PAT=replace_me

# TimescaleDB
POSTGRES_DB=oura
POSTGRES_USER=oura
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_PORT=5432

# Grafana admin login (first boot)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me
GF_SERVER_ROOT_URL=http://localhost:3000

# Sync cadence (cron expression — default: every 3 hours)
SYNC_SCHEDULE=0 */3 * * *

# Historical backfill on first run (days). Oura returns ~2 years.
BACKFILL_DAYS=730
